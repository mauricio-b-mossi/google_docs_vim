{
    "manifest_version": 3,
    "name": "Vim for Google Docs",
    "description": "Customizable Vim keybindings for Google Docs.",
    "version": "1.0.0",
    "icons": {
        "16": "icons/icon-16.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    },
    "permissions": [
        "storage",
        "activeTab"
    ],
    "background": {
        "service_worker": "src/background.js"
    },
    "content_scripts": [
        {
            "js": [
                "src/content.js"
            ],
            "matches": [
                "https://docs.google.com/*"
            ],
            "all_frames": true,
            "match_about_blank": true,
            "match_origin_as_fallback": true
        }
    ],
    "action": {
        "default_popup": "options.html"
    },
    "options_ui": {
        "page": "options.html",
        "open_in_tab": true
    }
}