{
  "manifest_version": 3,
  "name": "Vim for Google Docs",
  "description": "Customizable Vim keybindings for Google Docs.",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "activeTab"
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/content.js-ffSgs39I.js"
      ],
      "matches": [
        "https://docs.google.com/*"
      ],
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true
    }
  ],
  "action": {
    "default_popup": "options.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "matches": [
        "https://docs.google.com/*"
      ],
      "resources": [
        "assets/content.js-ffSgs39I.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
